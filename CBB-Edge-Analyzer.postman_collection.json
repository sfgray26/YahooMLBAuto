    {
      "name": "Momentum Detection",
      "description": "Analyze player hot/cold streaks using Z-score slope (ΔZ).",
      "item": [
        {
          "name": "Analyze Player Momentum",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"zScore14d\": 1.8,\n  \"zScore30d\": 0.4,\n  \"games14d\": 12,\n  \"games30d\": 24,\n  \"playerName\": \"Juan Soto\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/momentum/analyze",
              "host": ["{{baseUrl}}"],
              "path": ["momentum", "analyze"]
            },
            "description": "Calculate momentum from Z-scores. ΔZ = Z_14d − Z_30d. Returns trend (surging / hot / stable / cold / collapsing) and a buy/hold/sell recommendation."
          },
          "response": []
        },
        {
          "name": "Get Player Momentum (from DB)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/momentum/665742?season=2026",
              "host": ["{{baseUrl}}"],
              "path": ["momentum", "665742"],
              "query": [
                { "key": "season", "value": "2026" }
              ]
            },
            "description": "Look up momentum for a player from their persisted derived stats. Example: `665742` = Juan Soto. Requires data to be ingested first (run /admin/seed-uat or /admin/ingest-game-logs)."
          },
          "response": []
        },
        {
          "name": "Batch Momentum Analysis",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"players\": [\n    { \"playerId\": \"665742\", \"zScore14d\": 1.8, \"zScore30d\": 0.4, \"games14d\": 12, \"games30d\": 24 },\n    { \"playerId\": \"673237\", \"zScore14d\": -0.6, \"zScore30d\": 0.2, \"games14d\": 10, \"games30d\": 22 },\n    { \"playerId\": \"694817\", \"zScore14d\": 2.1, \"zScore30d\": 1.0, \"games14d\": 13, \"games30d\": 25 },\n    { \"playerId\": \"660670\", \"zScore14d\": 1.5, \"zScore30d\": 0.9, \"games14d\": 12, \"games30d\": 24 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/momentum/batch",
              "host": ["{{baseUrl}}"],
              "path": ["momentum", "batch"]
            },
            "description": "Calculate momentum for multiple players in a single request. Returns a summary of buy/sell signals and breakout/collapse warnings."
          },
          "response": []
        },
        {
          "name": "Get Hot Players (Leaders)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/momentum/leaders/hot?season=2026&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["momentum", "leaders", "hot"],
              "query": [
                { "key": "season", "value": "2026" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Returns players with the strongest positive momentum from the database."
          },
          "response": []
        }
      ]
    },
    {
      "name": "ROS Simulation",
      "description": "Monte Carlo rest-of-season projections and player comparisons.",
      "item": [
        {
          "name": "Run ROS Simulation (Single Player)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"playerId\": \"665742\",\n  \"season\": 2026,\n  \"config\": {\n    \"simulations\": 1000,\n    \"weeksRemaining\": 18,\n    \"gamesPerWeek\": 6,\n    \"confidenceLevel\": 0.9,\n    \"regressionToMean\": true\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/simulate/ros",
              "host": ["{{baseUrl}}"],
              "path": ["simulate", "ros"]
            },
            "description": "Run a Monte Carlo ROS projection for a single player. Returns percentile distribution (p10–p90), risk profile, and value-at-risk."
          },
          "response": []
        },
        {
          "name": "Run ROS Simulation (Batch)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
