    {
      "name": "Trade Evaluator",
      "description": "Evaluate trade proposals using ROS projections and category analysis.",
      "item": [
        {
          "name": "Get Trade Examples",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/trade/examples",
              "host": ["{{baseUrl}}"],
              "path": ["trade", "examples"]
            },
            "description": "Returns pre-built example trade payloads to copy into the evaluate endpoint."
          },
          "response": []
        },
        {
          "name": "Evaluate Trade (Full)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"proposal\": {\n    \"playersYouGive\": [\n      {\n        \"playerId\": \"mlbam:673237\",\n        \"playerMlbamId\": \"673237\",\n        \"name\": \"Yainer Diaz\",\n        \"positions\": [\"C\"],\n        \"team\": \"HOU\",\n        \"isInjured\": false,\n        \"gamesThisWeek\": 6\n      },\n      {\n        \"playerId\": \"mlbam:686469\",\n        \"playerMlbamId\": \"686469\",\n        \"name\": \"Vinnie Pasquantino\",\n        \"positions\": [\"1B\"],\n        \"team\": \"KC\",\n        \"isInjured\": false,\n        \"gamesThisWeek\": 6\n      }\n    ],\n    \"playersYouGet\": [\n      {\n        \"playerId\": \"mlbam:665742\",\n        \"playerMlbamId\": \"665742\",\n        \"name\": \"Juan Soto\",\n        \"positions\": [\"LF\", \"RF\"],\n        \"team\": \"NYM\",\n        \"isInjured\": false,\n        \"gamesThisWeek\": 6\n      }\n    ],\n    \"faabYouGive\": 0,\n    \"faabYouGet\": 0\n  },\n  \"teamState\": {\n    \"teamId\": \"my-team\",\n    \"teamName\": \"My Fantasy Team\"\n  },\n  \"config\": {\n    \"format\": \"roto\",\n    \"riskTolerance\": \"balanced\",\n    \"leagueSize\": 12,\n    \"currentWeek\": 8,\n    \"weeksRemaining\": 18\n  },\n  \"outputFormat\": \"json\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/trade/evaluate",
              "host": ["{{baseUrl}}"],
              "path": ["trade", "evaluate"]
            },
            "description": "Full trade evaluation using ROS projections, category impact, and risk assessment. Returns `recommendation` (strong_accept / lean_accept / neutral / lean_reject / hard_reject)."
          },
          "response": []
        },
        {
          "name": "Evaluate Trade (Markdown Output)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"proposal\": {\n    \"playersYouGive\": [\n      {\n        \"playerId\": \"mlbam:673237\",\n        \"playerMlbamId\": \"673237\",\n        \"name\": \"Yainer Diaz\",\n        \"positions\": [\"C\"],\n        \"team\": \"HOU\",\n        \"isInjured\": false,\n        \"gamesThisWeek\": 6\n      }\n    ],\n    \"playersYouGet\": [\n      {\n        \"playerId\": \"mlbam:694817\",\n        \"playerMlbamId\": \"694817\",\n        \"name\": \"Gunnar Henderson\",\n        \"positions\": [\"SS\", \"3B\"],\n        \"team\": \"BAL\",\n        \"isInjured\": false,\n        \"gamesThisWeek\": 6\n      }\n    ],\n    \"faabYouGive\": 0,\n    \"faabYouGet\": 0\n  },\n  \"config\": {\n    \"format\": \"roto\",\n    \"riskTolerance\": \"balanced\",\n    \"leagueSize\": 12\n  },\n  \"outputFormat\": \"markdown\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/trade/evaluate",
              "host": ["{{baseUrl}}"],
              "path": ["trade", "evaluate"]
            },
