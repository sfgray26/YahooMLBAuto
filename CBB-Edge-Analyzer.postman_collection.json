{
  "info": {
    "_postman_id": "cbb-edge-analyzer-v1",
    "name": "CBB Edge Analyzer API",
    "description": "Fantasy Baseball Intelligence API — Trade Evaluation, Momentum Detection, ROS Simulation, Lineup Optimization, and Waiver Wire Recommendations.\n\nSet the `baseUrl` variable to your deployed API (e.g. `https://your-app.railway.app`) or leave as `http://localhost:3000` for local development.\n\n**UAT Quick-Start:**\n1. Run **POST /admin/seed-uat** to populate the database with real MLB player data.\n2. Run **GET /health** to confirm the API is up.\n3. Test individual endpoints using the real MLBAM player IDs seeded in step 1.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "description": "Base URL of the API. Change this to your deployed Railway/production URL."
    },
    {
      "key": "requestId",
      "value": "",
      "description": "Populated automatically after queuing a lineup or waiver request. Use in the corresponding /result GET."
    }
  ],
  "item": [
    {
      "name": "Health",
      "description": "Service health and liveness checks.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Returns database connectivity status and overall service health."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Lineup Optimization",
      "description": "Queue and retrieve lineup optimization decisions.",
      "item": [
        {
          "name": "Request Lineup Optimization",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.requestId) {",
                  "  pm.collectionVariables.set('requestId', json.requestId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leagueId\": \"my-yahoo-league\",\n  \"platform\": \"yahoo\",\n  \"format\": \"h2h\",\n  \"scoringPeriod\": \"today\",\n  \"riskTolerance\": \"balanced\",\n  \"leagueSize\": 12,\n  \"availablePlayers\": {\n    \"players\": [\n      {\n        \"player\": {\n          \"id\": \"mlbam:673237\",\n          \"mlbamId\": \"673237\",\n          \"name\": \"Yainer Diaz\",\n          \"team\": \"HOU\",\n          \"position\": [\"C\"]\n        },\n        \"isAvailable\": true,\n        \"currentRosterStatus\": \"starting\"\n      },\n      {\n        \"player\": {\n          \"id\": \"mlbam:665742\",\n          \"mlbamId\": \"665742\",\n          \"name\": \"Juan Soto\",\n          \"team\": \"NYM\",\n          \"position\": [\"LF\", \"RF\"]\n        },\n        \"isAvailable\": true,\n        \"currentRosterStatus\": \"starting\"\n      },\n      {\n        \"player\": {\n          \"id\": \"mlbam:676979\",\n          \"mlbamId\": \"676979\",\n          \"name\": \"Garrett Crochet\",\n          \"team\": \"BOS\",\n          \"position\": [\"SP\"]\n        },\n        \"isAvailable\": true,\n        \"currentRosterStatus\": \"starting\"\n      }\n    ]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/lineup/today",
              "host": ["{{baseUrl}}"],
              "path": ["lineup", "today"]
            },
            "description": "Queue a lineup optimization request. Returns a `requestId` — use the *Get Lineup Result* request to poll for the outcome. The test script automatically saves `requestId` to the collection variable."
          },
          "response": []
        },
        {
          "name": "Get Lineup Result",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/lineup/{{requestId}}/result",
              "host": ["{{baseUrl}}"],
              "path": ["lineup", "{{requestId}}", "result"]
            },
            "description": "Poll for the result of a previously queued lineup optimization. Replace `{{requestId}}` with the ID returned by the POST request (automatically set if you ran the POST first)."
          },
          "response": []
        },
        {
          "name": "List Lineup Optimizations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/lineup/optimizations?limit=10&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["lineup", "optimizations"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "offset", "value": "0" }
              ]
            },
            "description": "List recent lineup optimization requests and their statuses."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Waiver Wire",
      "description": "Waiver wire recommendation requests and results.",
      "item": [
        {
          "name": "Request Waiver Recommendations",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.requestId) {",
                  "  pm.collectionVariables.set('requestId', json.requestId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leagueId\": \"my-yahoo-league\",\n  \"platform\": \"yahoo\",\n  \"format\": \"h2h\",\n  \"scope\": \"add_drop\",\n  \"leagueSize\": 12,\n  \"currentRoster\": [\n    {\n      \"player\": {\n        \"id\": \"mlbam:673237\",\n        \"mlbamId\": \"673237\",\n        \"name\": \"Yainer Diaz\",\n        \"team\": \"HOU\",\n        \"position\": [\"C\"]\n      },\n      \"position\": \"C\",\n      \"isLocked\": false\n    },\n    {\n      \"player\": {\n        \"id\": \"mlbam:665742\",\n        \"mlbamId\": \"665742\",\n        \"name\": \"Juan Soto\",\n        \"team\": \"NYM\",\n        \"position\": [\"LF\", \"RF\"]\n      },\n      \"position\": \"RF\",\n      \"isLocked\": false\n    },\n    {\n      \"player\": {\n        \"id\": \"mlbam:621439\",\n        \"mlbamId\": \"621439\",\n        \"name\": \"Byron Buxton\",\n        \"team\": \"MIN\",\n        \"position\": [\"CF\"]\n      },\n      \"position\": \"CF\",\n      \"isLocked\": false\n    }\n  ],\n  \"availablePlayers\": {\n    \"players\": [\n      {\n        \"player\": {\n          \"id\": \"mlbam:694817\",\n          \"mlbamId\": \"694817\",\n          \"name\": \"Gunnar Henderson\",\n          \"team\": \"BAL\",\n          \"position\": [\"SS\", \"3B\"]\n        },\n        \"isAvailable\": true\n      },\n      {\n        \"player\": {\n          \"id\": \"mlbam:660670\",\n          \"mlbamId\": \"660670\",\n          \"name\": \"Bobby Witt Jr.\",\n          \"team\": \"KC\",\n          \"position\": [\"SS\"]\n        },\n        \"isAvailable\": true\n      }\n    ]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/waiver/recommendations",
              "host": ["{{baseUrl}}"],
              "path": ["waiver", "recommendations"]
            },
            "description": "Queue a waiver wire recommendation request. The test script automatically saves `requestId` to the collection variable."
          },
          "response": []
        },
        {
          "name": "Get Waiver Result",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/waiver/{{requestId}}/result",
              "host": ["{{baseUrl}}"],
              "path": ["waiver", "{{requestId}}", "result"]
            },
            "description": "Poll for the result of a previously queued waiver recommendation."
          },
          "response": []
        },
        {
          "name": "List Waiver Requests",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/waiver/recommendations?limit=10&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["waiver", "recommendations"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "offset", "value": "0" }
              ]
            },
            "description": "List recent waiver recommendation requests."
          },
          "response": []
        },
        {
          "name": "Test With Real Roster",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/waiver/test-with-roster",
              "host": ["{{baseUrl}}"],
              "path": ["waiver", "test-with-roster"]
            },
            "description": "Convenience UAT endpoint — submits a pre-built waiver recommendation request using the real MLB roster hard-coded in the server (Yainer Diaz, Juan Soto, Garrett Crochet, etc.)."
          },
          "response": []
        },
        {
          "name": "View My Roster",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/waiver/my-roster",
              "host": ["{{baseUrl}}"],
              "path": ["waiver", "my-roster"]
            },
            "description": "Returns the hard-coded real MLB roster and waiver wire pool used by the test-with-roster endpoint."
          },
          "response": []
        }
      ]
    },
    {
