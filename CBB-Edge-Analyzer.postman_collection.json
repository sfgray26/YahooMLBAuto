              "raw": "{{baseUrl}}/players/673237/valuation",
              "host": ["{{baseUrl}}"],
              "path": ["players", "673237", "valuation"],
              "query": [
                { "key": "date", "value": "", "disabled": true, "description": "Optional ISO date, e.g. 2026-04-01" }
              ]
            },
            "description": "Get full derived features and valuation for a player by MLBAM ID. Example: `673237` = Yainer Diaz."
          },
          "response": []
