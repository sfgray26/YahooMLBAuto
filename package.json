{
  "name": "cbb-edge-analyzer",
  "version": "1.0.0",
  "private": true,
  "description": "Quantitative fantasy baseball decision engine",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "cd packages/infrastructure && pnpm prisma migrate dev",
    "db:generate": "cd packages/infrastructure && pnpm prisma generate",
    "db:seed": "cd packages/infrastructure && pnpm prisma db seed",
    "api:dev": "cd apps/api && pnpm dev",
    "worker:dev": "cd apps/worker && pnpm dev"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "vitest": "^1.6.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
