{
  "name": "cbb-edge-analyzer",
  "version": "1.0.0",
  "private": true,
  "description": "Quantitative fantasy baseball decision engine",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "cd packages/infrastructure && pnpm prisma migrate dev",
    "db:generate": "cd packages/infrastructure && pnpm prisma generate",
    "db:seed": "cd packages/infrastructure && pnpm prisma db seed",
    "db:test": "tsx scripts/test-persistence.ts",
    "data:ingest": "tsx scripts/ingest-balldontlie.ts",
    "data:compute": "tsx scripts/compute-derived-stats.ts",
    "data:ingest:dry": "tsx scripts/ingest-balldontlie.ts --dry-run --verbose",
    "data:compute:dry": "tsx scripts/compute-derived-stats.ts --dry-run --verbose",
    "test:balldontlie": "tsx scripts/test-balldontlie.ts",
    "test:derived": "tsx scripts/test-derived-computation.ts",
    "api:dev": "cd apps/api && pnpm dev",
    "worker:dev": "cd apps/worker && pnpm dev"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "vitest": "^1.6.0",
    "tsx": "^4.11.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
